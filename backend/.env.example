PORT=5000
NODE_ENV=development

# Local: mongodb://localhost:27017/mosque_finance
# Atlas: mongodb+srv://USER:PASSWORD@cluster.mongodb.net/mosque_finance?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/mosque_finance

JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:3000
UPLOAD_DIR=uploads

# Branding
MOSQUE_NAME=Mosque Finance
CURRENCY=INR
CURRENCY_SYMBOL=₹

# Optional integrations
WHATSAPP_API_URL=
SMS_API_KEY=
UPI_MERCHANT_ID=mosque.donations@upi
DONATION_GATEWAY_KEY=
